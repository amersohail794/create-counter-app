# ─── Production ──────────────────────────────────────────────────
# Deployed inside the enterprise portal. User is already logged in.
# Real SSOcookie is set by the SSO portal — no mocking needed.

VITE_USE_MOCK=false

# In production the app is served from the same origin as the API,
# so no base URL or proxy is needed.
VITE_API_BASE=
